    },
    {
      "key": "access_token",
      "value": "",
      "type": "string",
      "description": "JWT access token obtained from login"
    },
    {
      "key": "refresh_token",
      "value": "",
      "type": "string",
      "description": "JWT refresh token for token renewal"
    },
    {
      "key": "user_email",
      "value": "john.doe@example.com",
      "type": "string",
      "description": "Test user email"
    },
    {
      "key": "user_password",
      "value": "SecurePass123!",
      "type": "string",
      "description": "Test user password"
    },
    {
      "key": "transaction_id",
      "value": "",
      "type": "string",
      "description": "ID of a created transaction for testing"
    }
  ],
